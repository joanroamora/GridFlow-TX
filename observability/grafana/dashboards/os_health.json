  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "title": "🖥️ CPU Core Heatmap & Utilization (%)",
      "type": "heatmap",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "sum(rate(node_cpu_seconds_total{mode!=\"idle\"}[1m])) by (cpu)",
          "legendFormat": "CPU Core {{cpu}}",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "title": "🧠 RAM Memory Allocation & Swap Usage",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / 1024 / 1024",
          "legendFormat": "Used RAM (MB)",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "node_memory_MemAvailable_bytes / 1024 / 1024",
          "legendFormat": "Available RAM (MB)",
          "range": true,
          "refId": "B"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "title": "💽 Disk I/O Throughput (Read/Write MB/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "rate(node_disk_read_bytes_total[1m]) / 1024 / 1024",
          "legendFormat": "Read (MB/s)",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "rate(node_disk_written_bytes_total[1m]) / 1024 / 1024",
          "legendFormat": "Write (MB/s)",
          "range": true,
          "refId": "B"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "title": "🌐 Network Interface I/O (Rx/Tx KB/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "rate(node_network_receive_bytes_total{device!=\"lo\"}[1m]) / 1024",
          "legendFormat": "Rx Ingress (KB/s)",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "rate(node_network_transmit_bytes_total{device!=\"lo\"}[1m]) / 1024",
          "legendFormat": "Tx Egress (KB/s)",
          "range": true,
          "refId": "B"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "id": 5,
      "title": "📜 Live OS & Container Log Stream (Loki Severity Filter)",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "Loki" },
          "editorMode": "code",
          "expr": "{container_name=~\"gridflow-.*\"} |~ \"(?i)(ERROR|WARN|EXCEPTION|FAIL)\"",
          "queryType": "range",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "5s",
