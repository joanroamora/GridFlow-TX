      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "(sum(rate(gridflow_requests_total{status=\"error\"}[1m])) / sum(rate(gridflow_requests_total[1m]))) * 100",
